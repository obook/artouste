{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Artouste (debug gdb)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/artouste",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Affichage formate des conteneurs par gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "CMake : compiler",
            "detail": "Compile puis lance le simulateur sous gdb (touche F5)."
        }
    ]
}
